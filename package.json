    "check:bundle": "grep -rE 'sk-ant-api|AIzaSy|re_[a-zA-Z0-9]{20,}|LMSQ_|SERVICE_ROLE_KEY' .next/static/ 2>/dev/null && echo 'KEY LEAK DETECTED' && exit 1 || echo 'Bundle clean'",
